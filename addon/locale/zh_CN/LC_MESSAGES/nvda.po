#. Translators: Default name for a virtual desktop. {number} is the desktop number.
#: addon\globalPlugins\WinTeleport\__init__.py:74
#, python-brace-format
msgid "Desktop {number}"
msgstr "桌面 {number}"

#. Translators: The name of the category for this add-on's scripts in the Input Gestures dialog.
#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: addon\globalPlugins\WinTeleport\__init__.py:103 buildVars.py:21
msgid "WinTeleport"
msgstr "WinTeleport"

#. Translators: Describes a command in Input Help mode and Input Gestures dialog.
#: addon\globalPlugins\WinTeleport\__init__.py:168
msgid "Move the focused window to the left virtual desktop"
msgstr "将焦点窗口移动到左侧虚拟桌面"

#. Translators: Describes a command in Input Help mode and Input Gestures dialog.
#: addon\globalPlugins\WinTeleport\__init__.py:175
msgid "Move the focused window to the right virtual desktop"
msgstr "将焦点窗口移动到右侧虚拟桌面"

#. Translators: Describes a command in Input Help mode and Input Gestures dialog.
#: addon\globalPlugins\WinTeleport\__init__.py:182
msgid "Move the focused window to the left virtual desktop and switch to it"
msgstr "将焦点窗口移动到左侧虚拟桌面并切换到该窗口"

#. Translators: Describes a command in Input Help mode and Input Gestures dialog.
#: addon\globalPlugins\WinTeleport\__init__.py:190
msgid "Move the focused window to the right virtual desktop and switch to it"
msgstr "将焦点窗口移动到右侧虚拟桌面并切换到该窗口"

#. Translators: Describes a command in Input Help mode and Input Gestures dialog.
#: addon\globalPlugins\WinTeleport\__init__.py:198
msgid "Report the current virtual desktop"
msgstr "读出当前虚拟桌面信息"

#. Translators: Message for reporting current desktop.
#: addon\globalPlugins\WinTeleport\__init__.py:211
#, python-brace-format
msgid "{name} ({number} of {total})"
msgstr "{name} ({total} 之 {number} 项)"

#. Translators: Describes a command in Input Help mode and Input Gestures dialog.
#: addon\globalPlugins\WinTeleport\__init__.py:226
msgid "Move the focused window to the specified virtual desktop"
msgstr "将焦点窗口移动到指定的虚拟桌面"

#. Translators: Error message when no window is focused.
#: addon\globalPlugins\WinTeleport\__init__.py:234
#: addon\globalPlugins\WinTeleport\__init__.py:267
msgid "No focused window to move"
msgstr "没有要移动的焦点窗口"

#. Translators: Message when there is only one virtual desktop.
#: addon\globalPlugins\WinTeleport\__init__.py:239
msgid "Only one desktop available"
msgstr "仅有一个桌面"

#. Translators: Message when already on the first desktop.
#: addon\globalPlugins\WinTeleport\__init__.py:245
msgid "Already on the first desktop"
msgstr "已在第一个桌面"

#. Translators: Message when already on the last desktop.
#: addon\globalPlugins\WinTeleport\__init__.py:249
msgid "Already on the last desktop"
msgstr "已在最后一个桌面"

#. Translators: Error message when window move fails.
#: addon\globalPlugins\WinTeleport\__init__.py:254
#: addon\globalPlugins\WinTeleport\__init__.py:280
msgid "Failed to move window"
msgstr "无法移动窗口"

#. Translators: Message when desktop doesn't exist.
#: addon\globalPlugins\WinTeleport\__init__.py:272
#, python-brace-format
msgid "Desktop {number} does not exist. {total} desktops available."
msgstr "桌面 {number} 不存在，当前包含 {total} 个桌面。"

#. Translators: Message after moving window and switching desktop.
#: addon\globalPlugins\WinTeleport\__init__.py:292
#, python-brace-format
msgid "Moved and switched to {name}"
msgstr "移动并切换到{name}"

#. Translators: Message after moving window to another desktop.
#: addon\globalPlugins\WinTeleport\__init__.py:295
#, python-brace-format
msgid "Moved to {name}"
msgstr "移动到{name}"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "WinTeleport - Move windows between virtual desktops with keyboard shortcuts."
msgstr "WinTeleport - 使用键盘快捷键在虚拟桌面之间移动窗口。"

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "Initial version."
msgstr "初始版本。"
